# Wi-Fi credentials for the bedside clock.
#
# Copy this file to  secrets/wireless.env  and fill in your network below.
# `flash-os` writes it onto the SD card automatically right after flashing, so
# the device connects on first boot — no manual copy, ever.
#
# secrets/wireless.env is gitignored: it never enters the repo, the Nix store,
# or the built image. Fill it in once and it is reused for every flash.

WIFI_SSID="Your_WiFi_Name"
WIFI_PASSWORD="Your_WiFi_Password"
