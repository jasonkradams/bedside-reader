#cloud-config
manage_resolv_conf: false

hostname: bedside-reader
manage_etc_hosts: true
packages:
  - avahi-daemon
  - cog
  - libwpebackend-fdo-1.0-1
  - libwpewebkit-1.1-0
  - mpv
  - libmpv2
  - fonts-inter
  - libasound2
  - alsa-utils
  - network-manager
  - ffmpeg
apt:
  preserve_sources_list: true
  conf: |
    Acquire {
      Check-Date "false";
    };
timezone: America/Los_Angeles
keyboard:
  model: pc105
  layout: "us"
user:
  name: pi
  shell: /bin/bash
  lock_passwd: true
  ssh_authorized_keys:
    - "ssh-rsa "
    - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFi9PGouQ/5XIMO6NSUzOqVPkPBFR9DmWDOjF1CZ96Io"
ssh_pwauth: false

write_files:
  - path: /etc/udev/rules.d/90-backlight.rules
    owner: root:root
    permissions: '0644'
    content: |
      SUBSYSTEM=="backlight", ACTION=="add", \
        RUN+="/bin/chgrp video /sys/class/backlight/%k/brightness", \
        RUN+="/bin/chmod g+w /sys/class/backlight/%k/brightness"

  - path: /etc/systemd/system/bedside.service
    owner: root:root
    permissions: '0644'
    content: |
      [Unit]
      Description=Bedside Audiobook Player
      After=network-online.target sound.target
      Wants=network-online.target

      [Service]
      Type=notify
      ExecStart=/usr/local/bin/bedside
      Restart=always
      RestartSec=2
      User=bedside
      Group=bedside
      SupplementaryGroups=audio gpio video
      StateDirectory=bedside
      ReadWritePaths=/var/lib/bedside
      ProtectSystem=strict
      ProtectHome=true
      NoNewPrivileges=true
      WatchdogSec=30

      [Install]
      WantedBy=multi-user.target

  - path: /etc/systemd/system/cog.service
    owner: root:root
    permissions: '0644'
    content: |
      [Unit]
      Description=Bedside Kiosk (Cog on KMS/DRM)
      After=bedside.service systemd-user-sessions.service
      Requires=bedside.service
      ConditionPathExists=/dev/dri/card0

      [Service]
      Type=simple
      User=bedside
      Group=bedside
      SupplementaryGroups=video render input

      # No DISPLAY, no XAUTHORITY. Cog renders straight to /dev/dri/card0.
      Environment=WEBKIT_DISABLE_COMPOSITING_MODE=0
      Environment=XDG_RUNTIME_DIR=/run/user/%U

      ExecStartPre=/usr/bin/sh -c 'until curl -fsS http://localhost:8080/healthz; do sleep 0.3; done'
      ExecStart=/usr/bin/cog \
        --platform=drm \
        --geometry=320x240 \
        --bg-color=000000 \
        http://localhost:8080

      Restart=always
      RestartSec=2

      [Install]
      WantedBy=multi-user.target

runcmd:
  - [ systemctl, enable, --now, ssh ]
  - [ groupadd, -f, bedside ]
  - [ useradd, -r, -g, bedside, -G, "audio,gpio,video,render,input", -s, /usr/sbin/nologin, bedside ]
  - [ udevadm, control, --reload-rules ]
  - [ udevadm, trigger ]
  - [ systemctl, daemon-reload ]
  - [ systemctl, enable, bedside.service ]
  - [ systemctl, enable, cog.service ]
